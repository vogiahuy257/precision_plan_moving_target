[Unit]
Description=ArUco Tracker ROS2 Node
After=microxrce-agent.service
Wants=rtsp-camera.service

[Service]
Type=simple
User=pihuy
WorkingDirectory=/home/pihuy/Precision-Landing
ExecStart=/bin/bash /home/pihuy/Precision-Landing/services/start_aruco_tracker.sh
Restart=on-failure
RestartSec=2
KillSignal=SIGINT
Environment=RMW_IMPLEMENTATION=rmw_fastrtps_cpp
Environment=ROS_DOMAIN_ID=0
Environment=RMW_FASTRTPS_USE_SHM=0
Environment=HOME=/home/pihuy

[Install]
WantedBy=multi-user.target

